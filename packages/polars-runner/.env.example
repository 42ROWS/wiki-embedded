# polars-runner — environment variables for local Docker runs and tests.
# Copy to .env.local and fill in your values. Never commit .env.local.

# ── LLM keys ──────────────────────────────────────────────────────────────────
# Gemini 2.5 Pro — used by the property-based oracle generator (extracts a
# verifiable contract from each prompt). Falls back to Anthropic / OpenAI / Groq
# if Gemini is unavailable. Get keys at:
#   https://aistudio.google.com           (Gemini)
#   https://console.anthropic.com          (Anthropic)
#   https://platform.openai.com            (OpenAI)
#   https://console.groq.com               (Groq, free tier)
GEMINI_PRO_API_KEY=
GEMINI_HOSTED_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── RAG skill library (auto-improving cache) ──────────────────────────────────
# Pinecone Inference stores Polars code that passed the oracle so the runner
# can reuse it as few-shot examples for similar future prompts.
#   https://app.pinecone.io
PINECONE_API_KEY=

# ── Oracle toggles ────────────────────────────────────────────────────────────
# The PBT oracle is the default quality gate. Disable explicitly here if you
# want raw codegen with no contract verification.
# POLARS_RUNNER_DISABLE_ORACLE=1
# Run the oracle in advisory mode (report mismatches without retrying):
# POLARS_RUNNER_ORACLE_ADVISORY=1

# ── Runtime tuning (optional) ─────────────────────────────────────────────────
# LOG_LEVEL=INFO
# CODE_TIMEOUT_SECONDS=30
# MAX_MEMORY_MB=512
# MAX_RETRIES=3

# ── Apify (only needed when deploying as an Apify Actor) ──────────────────────
APIFY_TOKEN=
APIFY_IS_AT_HOME=false

# ── Local Docker harness ──────────────────────────────────────────────────────
# Used by builds/docker/docker-compose.yml when running the actor locally.
# INPUT_FILE=builds/docker/data/input.json
# OUTPUT_DIR=builds/docker/output
