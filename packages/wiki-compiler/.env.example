# wiki-compiler — environment variables for local Docker runs and tests.
# Copy to .env.local and fill in your values. Never commit .env.local.

# ── LLM keys ──────────────────────────────────────────────────────────────────
# Anthropic Claude — used by thesis_builder to derive the wiki "lens"
# (target audience, key concepts, excluded topics). Get a key at:
#   https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — used by chunk_generator (Flash teacher mode) to pre-compute
# answer chunks per page. Either key works; GEMINI_HOSTED_API_KEY is checked
# first, GOOGLE_API_KEY is the fallback. Get a key at:
#   https://aistudio.google.com
GEMINI_HOSTED_API_KEY=
GOOGLE_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
# Pinecone Inference (cloud E5 multilingual). Required when running the
# embedder with a `pinecone:` model name. Get a key at:
#   https://app.pinecone.io
PINECONE_API_KEY=

# ── Apify (only needed when deploying as an Apify Actor) ──────────────────────
APIFY_TOKEN=
